// SCRIPT DE ASSINATURA
// ══════════════════════════════════════════════════════════════════
function scriptAssinatura(d) {
  return `
<script>
const canvas = document.getElementById('sig-canvas');
const ctx = canvas.getContext('2d');
let drawing = false, signed = false;
let lastX = 0, lastY = 0;
ctx.strokeStyle = '#72243E'; ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

function getPos(e) {
  const r = canvas.getBoundingClientRect();
  const sx = canvas.width / r.width, sy = canvas.height / r.height;
  return e.touches
    ? {x:(e.touches[0].clientX-r.left)*sx, y:(e.touches[0].clientY-r.top)*sy}
    : {x:(e.clientX-r.left)*sx, y:(e.clientY-r.top)*sy};
}
canvas.addEventListener('mousedown', e=>{drawing=true;const p=getPos(e);lastX=p.x;lastY=p.y;});
canvas.addEventListener('mousemove', e=>{if(!drawing)return;const p=getPos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;});
canvas.addEventListener('mouseup', ()=>drawing=false);
canvas.addEventListener('mouseleave', ()=>drawing=false);
canvas.addEventListener('touchstart', e=>{e.preventDefault();drawing=true;const p=getPos(e);lastX=p.x;lastY=p.y;},{passive:false});
canvas.addEventListener('touchmove', e=>{e.preventDefault();if(!drawing)return;const p=getPos(e);ctx.beginPath();ctx.moveTo(lastX,lastY);ctx.lineTo(p.x,p.y);ctx.stroke();lastX=p.x;lastY=p.y;},{passive:false});
canvas.addEventListener('touchend', ()=>drawing=false);

function clearSig(){ctx.clearRect(0,0,canvas.width,canvas.height);signed=false;}

function confirmSig(){
  const blank=!ctx.getImageData(0,0,canvas.width,canvas.height).data.some(v=>v!==0);
  if(blank){alert('Por favor, assine antes de confirmar.');return;}
  signed=true;
  const now=new Date();
  const dateStr=now.toLocaleDateString('pt-BR')+' às '+now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  document.getElementById('sig-date-label').textContent=dateStr;
  document.getElementById('sig-status').className='status-bar status-signed';
  document.getElementById('sig-status').textContent='✅ Contrato assinado digitalmente em '+dateStr;
  canvas.style.pointerEvents='none';canvas.style.opacity='0.85';
  document.querySelector('.sig-actions').innerHTML='<span style="font-size:12px;color:#27500A;font-weight:500">✅ Assinado com sucesso</span>';
  const sigData=canvas.toDataURL('image/png');
  fetch('https://ribbitingboar-n8n.cloudfy.live/webhook/contrato-assinado',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      contrato_id:'${d.numeroContrato || ""}',
      agendamento_id:'${d.agendamentoId || ""}',
      assinatura:sigData,
      signed_at:now.toISOString(),
      cliente_email:'${d.emailCliente || ""}',
      cliente_nome:'${d.nomeCliente || ""}',
      cliente_whatsapp:'${d.whatsappCliente || ""}',
    })
  }).catch(()=>{});
}

${d.temMenor ? `
const canvasResp = document.getElementById('sig-canvas-resp');
if(canvasResp){
  const ctxR=canvasResp.getContext('2d');
  let drawingR=false,lastXR=0,lastYR=0;
  ctxR.strokeStyle='#72243E';ctxR.lineWidth=2;ctxR.lineCap='round';
  function getPosR(e){const r=canvasResp.getBoundingClientRect();const sx=canvasResp.width/r.width,sy=canvasResp.height/r.height;return e.touches?{x:(e.touches[0].clientX-r.left)*sx,y:(e.touches[0].clientY-r.top)*sy}:{x:(e.clientX-r.left)*sx,y:(e.clientY-r.top)*sy};}
  canvasResp.addEventListener('mousedown',e=>{drawingR=true;const p=getPosR(e);lastXR=p.x;lastYR=p.y;});
  canvasResp.addEventListener('mousemove',e=>{if(!drawingR)return;const p=getPosR(e);ctxR.beginPath();ctxR.moveTo(lastXR,lastYR);ctxR.lineTo(p.x,p.y);ctxR.stroke();lastXR=p.x;lastYR=p.y;});
  canvasResp.addEventListener('mouseup',()=>drawingR=false);
  canvasResp.addEventListener('mouseleave',()=>drawingR=false);
  canvasResp.addEventListener('touchstart',e=>{e.preventDefault();drawingR=true;const p=getPosR(e);lastXR=p.x;lastYR=p.y;},{passive:false});
  canvasResp.addEventListener('touchmove',e=>{e.preventDefault();if(!drawingR)return;const p=getPosR(e);ctxR.beginPath();ctxR.moveTo(lastXR,lastYR);ctxR.lineTo(p.x,p.y);ctxR.stroke();lastXR=p.x;lastYR=p.y;},{passive:false});
  canvasResp.addEventListener('touchend',()=>drawingR=false);
  window.clearSigResp=()=>ctxR.clearRect(0,0,canvasResp.width,canvasResp.height);
  window.confirmSigResp=()=>{canvasResp.style.pointerEvents='none';canvasResp.style.opacity='0.85';};
}` : ""}
</script>`;
}

