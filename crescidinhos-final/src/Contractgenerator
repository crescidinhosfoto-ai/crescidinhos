  <!-- BLOCO D: ASSINATURA -->
  ${blocoAssinatura(d)}

  <div class="footer-doc">
    ${PHOTOGRAPHER.name} · CNPJ ${PHOTOGRAPHER.cnpj}<br/>
    ${PHOTOGRAPHER.endereco}<br/>
