  <!-- BLOCO A: PARTES -->
  ${blocoPartes(d)}

  <!-- BLOCO B: SERVIÇO -->
  ${blocoServico(d)}

  <!-- BLOCO ESPECÍFICO -->
  <div class="clauses">
    ${blocoEspecifico(d)}

    <!-- BLOCO C: CLÁUSULAS GERAIS -->
    ${blocoClausulasGerais(d)}
